PORT=3000
NODE_ENV=development

# polling for local testing, webhook for Render/Railway/VPS
BOT_MODE=polling

# Telegram
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Required when BOT_MODE=webhook
WEBHOOK_URL=https://your-app.example.com/telegram/webhook
PUBLIC_BASE_URL=https://your-app.example.com

# Optional webhook security
TELEGRAM_WEBHOOK_SECRET=

# Optional: required for external order status webhook calls
ORDER_WEBHOOK_API_KEY=replace_with_long_random_secret

# Optional: clear webhook when switching back to local polling
TELEGRAM_CLEAR_WEBHOOK_ON_POLL=true
